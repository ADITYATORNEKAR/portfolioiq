# ============================================================
# HFT Causal Platform — Environment Variables
# All API keys are FREE to obtain. No credit card required.
# ============================================================

# --- Finnhub (Real-time quotes + news) ---
# Free signup: https://finnhub.io/register
# Free tier: 60 REST calls/min, WebSocket included
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- FRED (Macro economic indicators) ---
# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
# Completely free, no rate limits for reasonable use
FRED_API_KEY=your_fred_api_key_here

# --- Groq (AI Agent LLM — Llama 3.3 70B) ---
# Free signup: https://console.groq.com
# Free tier: Llama-3.3-70b, 6000 tokens/min, no CC required
GROQ_API_KEY=your_groq_api_key_here

# --- App Config ---
# For local development
ENVIRONMENT=development
DB_PATH=/tmp/hft_causal.db
